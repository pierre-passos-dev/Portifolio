---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not Found">
  <section style="min-height:100svh;display:flex;align-items:center;justify-content:center;text-align:center;padding:2rem;">
    <div>
      <p style="font-family:var(--font-mono);color:var(--accent);font-size:0.85rem;letter-spacing:0.1em;margin-bottom:1rem;">// 404</p>
      <h1 style="font-size:clamp(3rem,10vw,6rem);font-weight:800;letter-spacing:-0.04em;color:var(--text-primary);margin-bottom:1rem;">Página não encontrada</h1>
      <p style="color:var(--text-secondary);margin-bottom:2rem;">Page not found</p>
      <a href="/" style="display:inline-flex;align-items:center;gap:.5rem;padding:.75em 1.5em;background:var(--accent);color:var(--bg-base);border-radius:var(--radius-md);font-weight:600;font-size:.9rem;">
        ← Voltar / Back
      </a>
    </div>
  </section>
</BaseLayout>
