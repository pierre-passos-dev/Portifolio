---
// src/components/Experience.astro
import { useTranslations, type Lang } from '../i18n/translations';
import { experiences } from '../data/experience';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section experience" id="experience">
  <div class="container">
    <span class="section-label">// {lang === 'pt' ? '04. experiência' : '04. experience'}</span>
    <h2 class="section-title">{t('exp.title')}</h2>

    <div class="timeline">
      {experiences.map((exp, i) => (
        <div class="timeline__item" data-reveal style={`transition-delay: ${i * 0.12}s`}>
          <div class="timeline__marker">
            <div class="timeline__dot"></div>
            {i < experiences.length - 1 && <div class="timeline__line"></div>}
          </div>
          <div class="timeline__content">
            <div class="timeline__meta">
              <span class="timeline__period">{exp.period}</span>
              <span class="timeline__company">{exp.company}</span>
            </div>
            <h3 class="timeline__role">
              {lang === 'pt' ? exp.rolePt : exp.roleEn}
            </h3>
            <p class="timeline__desc">
              {lang === 'pt' ? exp.descPt : exp.descEn}
            </p>
            <div class="timeline__tags">
              {exp.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.timeline {
  display: flex;
  flex-direction: column;
  gap: 0;
  max-width: 700px;
}

.timeline__item {
  display: grid;
  grid-template-columns: 40px 1fr;
  gap: 1.5rem;
  padding-bottom: 2.5rem;
}

.timeline__marker {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 4px;
}
.timeline__dot {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: var(--accent);
  border: 3px solid var(--bg-base);
  box-shadow: 0 0 0 2px var(--accent);
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}
.timeline__line {
  width: 1px;
  flex: 1;
  background: linear-gradient(to bottom, var(--accent), var(--border));
  margin-top: 6px;
  min-height: 40px;
}

.timeline__content {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.timeline__meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}
.timeline__period {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--accent);
  letter-spacing: 0.05em;
}
.timeline__company {
  font-size: 0.8rem;
  color: var(--text-muted);
  font-weight: 500;
  background: var(--bg-elevated);
  padding: 0.15em 0.6em;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
}
.timeline__role {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}
.timeline__desc {
  font-size: 0.875rem;
  color: var(--text-secondary);
  line-height: 1.75;
}
.timeline__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-top: 0.25rem;
}
</style>
